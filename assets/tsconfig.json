{
    "extends": "../base.tsconfig.json",
    "compilerOptions": {
        "noEmit": true,
        "rootDir": "../../",
        "target": "es2019",
        "strict": false,
        "ignoreDeprecations": "6.0",
        "types": [
            "../../../temp/declarations/cc",
            "../../../temp/declarations/jsb",
            "../../../temp/declarations/cc.env",
            "../../../temp/declarations/cc.custom-macro"
        ],
        "paths": {
            "db://internal/*": [
                "../../../pTS_cc_engine_3x/editor/assets/*"
            ],
            "db://assets/*": [
                "../../../assets/*"
            ],
            "db://pts-asset/*": [
                "../../pts-asset/assets/*"
            ],
            "db://pts-core/*": [
                "../../pts-core/assets/*"
            ],
            "db://pts-multi-game-sdk/*": [
                "./*"
            ]
        }
    },
    "include": [
        "**/*",
        ".dev/**/*",
        "../../../assets/.dev/**/*.d.ts"
    ]
}
